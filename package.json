{
  "name": "root",
  "description": "Its Penbot",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "fix": "rm -rf node_modules ; rm -rf ./docs/node_modules/ ; rm -rf ./packages/core/node_modules ; bun --bun i ;  cd docs && npx svelte-kit sync && cd .. ; cd packages/core && npx svelte-kit sync && cd ..  ",
    "prepare": "bun run package && bun run sync && prek install",
    "package": "bun run --filter '@penbot/core' build",
    "sync": "bun run --filter '*' --parallel sync",
    "clean": "fd -t d '.svelte-kit' --hidden -I -x rm -rf && fd -t d 'node_modules' --hidden -I -x rm -rf && fd -t d 'build/' --hidden -I -x rm -rf",
    "build": "bun --bun build:packages && bun --bun build:docs",
    "build:packages": "bun --bun run --filter \"./packages/**\" --parallel build",
    "build:docs": "bun --bun run --elide-lines=0 --filter '@penbot/docs' build",
    "check": "bun --bun build:packages && bun --bun -r check",
    "dev": "bun --bun run --filter './packages/*' sync && bun run --filter '*' --filter '!pkg-ignore-me' dev",
    "format": "biome format --write --verbose --line-ending=lf .",
    "lint": "biome lint --diagnostic-level=error --no-errors-on-unmatched .",
    "docs:version": "bun run --filter @penbot/mds version",
    "docs:version:add": "bun run --filter @penbot/mds version add",
    "docs:version:remove": "bun run --filter @penbot/mds version remove",
    "docs:version:sync": "bun run --filter @penbot/mds version sync",
    "docs:sections": "bun run --filter @penbot/mds sections"
  },
  "engines": {
    "pnpm": ">=10.12.1",
    "node": ">=20"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "docs"
    ],
    "catalog": {
      "@sveltejs/kit": "^2.42.1",
      "@sveltejs/vite-plugin-svelte": "^6.2.0",
      "@tailwindcss/vite": "^4.1.13",
      "@types/node": "^22.18.6",
      "svelte": "^5.39.3",
      "svelte-check": "^4.3.1",
      "tailwindcss": "^4.1.13",
      "mode-watcher": "^1.0.2",
      "typescript": "^5.9.2",
      "tw-animate-css": "^1.4.0",
      "tailwind-variants": "^1.0.0",
      "tailwind-merge": "^3.1.0",
      "bits-ui": "^2.11.0",
      "clsx": "^2.1.1",
      "@types/bun": "^1.3.5",
      "vite": "npm:rolldown-vite@latest"
    }
  },
  "trustedDependencies": [
    "@sveltejs/kit",
    "esbuild",
    "workerd"
  ],
  "packageManager": "pnpm@10.15.1",
  "devDependencies": {
    "@biomejs/biome": "^2.3.4",
    "@j178/prek": "^0.2.13",
    "@changesets/cli": "^2.29.7",
    "@eslint/compat": "^1.3.2",
    "@eslint/js": "^9.36.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@svitejs/changesets-changelog-github-compact": "^1.2.0",
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.16.0",
    "eslint-plugin-svelte": "^3.12.3",
    "globals": "^16.4.0",
    "oxlint": "^1.16.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "svelte": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "^8.44.0",
    "wrangler": "^4.38.0"
  }
}
